# Frontend port for `npm run dev`
PORT=3000

# Backend API port used when NEXT_PUBLIC_API_BASE is not set.
NEXT_PUBLIC_API_PORT=4000

# Optional explicit API base.
# Leave this commented if frontend and backend run on the same host and only the port changes.
# NEXT_PUBLIC_API_BASE=http://localhost:4000
# NEXT_PUBLIC_API_BASE=http://89.117.21.252:4000

# Public frontend URL for auth / OAuth callback flows.
NEXTAUTH_URL=http://localhost:3000

# Microsoft identity (required for calendar + auth flows)
MS_CLIENT_ID=your-client-id
MS_CLIENT_SECRET=your-client-secret
MS_TENANT_ID=common

NEXTAUTH_SECRET=replace-with-a-secure-secret
NEXT_TELEMETRY_DISABLED=1
